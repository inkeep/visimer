{
  "name": "@visimer/dom",
  "version": "0.1.0",
  "description": "Interactive WYSIWYG canvas for Mermaid: renders through mermaid itself and overlays selection, drag-to-connect, inline label editing, and code sync.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "build": "tsup src/index.ts --format esm --dts --sourcemap --out-dir dist"
  },
  "dependencies": {
    "@visimer/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.9",
    "jsdom": "^25.0.1"
  },
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "author": "Inkeep",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkeep/visimer.git",
    "directory": "packages/dom"
  },
  "homepage": "https://github.com/inkeep/visimer#readme",
  "bugs": "https://github.com/inkeep/visimer/issues",
  "keywords": [
    "mermaid",
    "wysiwyg",
    "diagram",
    "editor",
    "flowchart",
    "visual-editing"
  ],
  "sideEffects": false
}
