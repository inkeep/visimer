# PostHog site analytics (optional). Public write-only key — safe to expose
# in the client bundle. Leave empty to disable analytics entirely (local dev,
# forks). Set in the Vercel project env for production.
VITE_POSTHOG_KEY=

# Ingestion host override. Defaults to /ingest, which vercel.json proxies to
# PostHog US cloud so ad blockers don't drop events. Point it at
# https://eu.i.posthog.com for EU-cloud projects (and swap the vercel.json
# rewrite targets to the eu hosts too).
VITE_POSTHOG_HOST=
